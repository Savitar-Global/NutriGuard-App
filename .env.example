# Copy this file to .env and fill in real values
# NEVER commit .env to git

# OpenAI — get from platform.openai.com/api-keys
# WARNING (MVP): key is bundled in the app. Migrate to Cloud Function before public launch.
EXPO_PUBLIC_OPENAI_API_KEY=sk-proj-replace-me

# RevenueCat — get from app.revenuecat.com → Project → API Keys (only used on physical-device Dev Client builds)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_replace-me

# Firebase Web SDK config — get from Firebase Console → Project settings → General → Your apps → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=AIza...
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=nutriguard-xxxx.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=nutriguard-xxxx
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=nutriguard-xxxx.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
EXPO_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
